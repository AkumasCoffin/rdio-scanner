<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security policy.

    Rdio Scanner servers are commonly self-hosted on a LAN and reached over
    plain http:// / ws://, so cleartext traffic is permitted here. If you
    only ever connect to a public server over HTTPS, tighten this to
    cleartextTrafficPermitted="false" and drop the private-address block.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Debug builds additionally trust user-installed CAs for easy
         proxying / packet capture against self-hosted test servers. -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
