<?xml version="1.0" encoding="utf-8"?>
<!--
    Monochrome variant for Android 13+ themed icons. Solid black silhouette;
    the system recolors it from the active Material You palette at runtime.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108"
    android:tint="#000000">

    <!-- Outermost signal arc -->
    <path
        android:pathData="M 22 54 a 32 32 0 0 1 64 0"
        android:strokeWidth="5"
        android:strokeColor="#000000"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:strokeAlpha="0.35" />

    <!-- Middle signal arc -->
    <path
        android:pathData="M 32 54 a 22 22 0 0 1 44 0"
        android:strokeWidth="5"
        android:strokeColor="#000000"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:strokeAlpha="0.65" />

    <!-- Inner signal arc -->
    <path
        android:pathData="M 42 54 a 12 12 0 0 1 24 0"
        android:strokeWidth="5"
        android:strokeColor="#000000"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <!-- LED / antenna dot -->
    <path
        android:pathData="M 54 52 m -5 0 a 5 5 0 1 0 10 0 a 5 5 0 1 0 -10 0"
        android:fillColor="#000000" />

    <!-- Scanner body -->
    <path
        android:pathData="M 30 60 h 48 a 4 4 0 0 1 4 4 v 18 a 4 4 0 0 1 -4 4 h -48 a 4 4 0 0 1 -4 -4 v -18 a 4 4 0 0 1 4 -4 z m 4 4 a 2 2 0 0 0 -2 2 v 10 a 2 2 0 0 0 2 2 h 40 a 2 2 0 0 0 2 -2 v -10 a 2 2 0 0 0 -2 -2 z"
        android:fillColor="#000000"
        android:fillType="evenOdd" />
</vector>
